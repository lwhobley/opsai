# =============================================
# Ops AI — Backend Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================

# --- Database ---
# Supabase PostgreSQL Transaction Pooler URL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Auth ---
# Strong random secret for JWT signing — generate with: openssl rand -hex 64
JWT_SECRET=

# Initial admin PIN (min 6 digits recommended). Only used on first startup to seed the admin user.
# Change this PIN immediately after first login via User Management.
ADMIN_PIN=

# --- AI ---
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://ops.enishhouston.com,http://localhost:3000
FRONTEND_URL=http://localhost:3000
