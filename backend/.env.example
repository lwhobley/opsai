# =============================================
# Ops AI — Backend Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================

# --- Database ---
# Supabase PostgreSQL Transaction Pooler URL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Auth ---
# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET=

# Initial admin PIN (4 or 6 digits). Used only on first startup.
# Change via User Management after first login.
ADMIN_PIN=

# Set to "true" in production (HTTPS only)
COOKIE_SECURE=false

# --- AI ---
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://ops.enishhouston.com,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- Toast POS ---
# Leave unset to use production Toast API (default)
# Set to sandbox URL for testing: https://ws-sandbox-api.eng.toasttab.com
TOAST_API_BASE_URL=

# --- Cost Targets ---
# Adjust to match Enish Houston's actual targets
TARGET_POUR_COST_PCT=20.0
TARGET_FOOD_COST_PCT=30.0

# --- Rate Limiting ---
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=300

# Toast POS — Bar Revenue Center GUIDs (comma-separated)
# Get from Toast Web → Integrations → API Access → Revenue Centers
# Without this, bar/food split falls back to name-based heuristic
TOAST_BAR_REVENUE_CENTER_GUIDS=

# Web Push Notifications (future)
# Must be a real mailto address — push providers reject placeholder domains
VAPID_MAILTO=admin@yourdomain.com
